# Supabase (local values come from `pnpm dlx supabase status`)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Server-only. Bypasses RLS. Never expose to the browser.
SUPABASE_SECRET_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend (transactional email). Get an API key + verified domain at resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=encouraged <onboarding@yourdomain.com>

# Shared secret for the Vercel Cron endpoint
CRON_SECRET=
